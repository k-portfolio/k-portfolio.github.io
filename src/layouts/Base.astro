---
import { GITHUB_URL, SITE_DESCRIPTION } from '../consts';

interface Props {
  title: string;
  description?: string;
}
const { title, description = SITE_DESCRIPTION } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="brand">Portfolio</a>
        <nav class="nav" aria-label="グローバルナビゲーション">
          <a href="/#works">成果物</a>
          <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer">GitHub</a>
        </nav>
      </div>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>© {new Date().getFullYear()} Portfolio</p>
      </div>
    </footer>

    <style is:global>
      :root {
        --bg: #ffffff;
        --bg-soft: #f6f7f9;
        --text: #1a1d21;
        --text-muted: #5a6472;
        --border: #e3e6ea;
        --accent: #2563eb;
        --accent-hover: #1d4ed8;
        --radius: 12px;
        --maxw: 880px;
        --font: system-ui, -apple-system, "Segoe UI", "Hiragino Kaku Gothic ProN",
          "Noto Sans JP", Meiryo, sans-serif;
      }

      * { box-sizing: border-box; }
      html { -webkit-text-size-adjust: 100%; scroll-behavior: smooth; }
      body {
        margin: 0;
        font-family: var(--font);
        color: var(--text);
        background: var(--bg);
        line-height: 1.75;
        font-size: 16px;
        -webkit-font-smoothing: antialiased;
      }

      .container {
        width: 100%;
        max-width: var(--maxw);
        margin-inline: auto;
        padding-inline: 20px;
      }

      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; }
      img { max-width: 100%; height: auto; display: block; }

      /* header */
      .site-header {
        position: sticky;
        top: 0;
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(8px);
        border-bottom: 1px solid var(--border);
        z-index: 10;
      }
      .header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 56px;
      }
      .brand { font-weight: 700; color: var(--text); }
      .nav a { margin-left: 18px; color: var(--text-muted); font-size: 0.95rem; }
      .nav a:hover { color: var(--text); }

      main.container { padding-block: 44px 64px; }

      .site-footer {
        border-top: 1px solid var(--border);
        color: var(--text-muted);
        font-size: 0.85rem;
        padding-block: 24px;
      }
      .site-footer p { margin: 0; }

      /* profile */
      .profile h1 { font-size: 2rem; margin: 0 0 8px; letter-spacing: 0.01em; }
      .profile .lead { color: var(--text-muted); margin: 0 0 16px; font-size: 1.05rem; }
      .meta-list {
        display: flex; flex-wrap: wrap; gap: 6px 20px;
        padding: 0; margin: 0 0 14px; list-style: none;
        color: var(--text-muted); font-size: 0.95rem;
      }
      .meta-list li { position: relative; }
      .meta-list li::before { content: "・"; }

      /* tags */
      .tags { display: flex; flex-wrap: wrap; gap: 6px; padding: 0; margin: 14px 0 0; list-style: none; }
      .tag {
        font-size: 0.8rem; background: var(--bg-soft); border: 1px solid var(--border);
        color: var(--text-muted); padding: 2px 10px; border-radius: 999px; line-height: 1.6;
      }

      /* sections */
      section { margin-top: 52px; }
      .section-title {
        font-size: 1.3rem; border-bottom: 2px solid var(--border);
        padding-bottom: 8px; margin-bottom: 22px;
      }

      /* work grid */
      .work-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 18px;
      }
      .work-card {
        border: 1px solid var(--border); border-radius: var(--radius);
        overflow: hidden; background: var(--bg);
        transition: box-shadow 0.15s ease, transform 0.15s ease;
      }
      .work-card:hover { box-shadow: 0 6px 22px rgba(0, 0, 0, 0.08); transform: translateY(-2px); }
      .work-card .card-link { color: inherit; text-decoration: none; display: flex; flex-direction: column; height: 100%; }
      .work-card .card-link:hover { text-decoration: none; }
      .work-card .thumb { aspect-ratio: 16 / 9; width: 100%; object-fit: cover; background: var(--bg-soft); }
      .thumb-placeholder {
        display: flex; align-items: center; justify-content: center;
        background: linear-gradient(135deg, #e0e7ff, #f1f5f9);
        color: var(--accent); font-size: 2rem; font-weight: 700;
      }
      .work-card .card-body { padding: 16px; display: flex; flex-direction: column; gap: 8px; flex: 1; }
      .work-card h3 { margin: 0; font-size: 1.05rem; }
      .work-card .card-body p { margin: 0; color: var(--text-muted); font-size: 0.9rem; }

      /* detail */
      .work-detail .back { display: inline-block; margin-bottom: 16px; font-size: 0.9rem; }
      .work-detail h1 { font-size: 1.8rem; margin: 0 0 8px; }
      .work-detail .lead { color: var(--text-muted); margin: 0; }
      .links { display: flex; flex-wrap: wrap; gap: 12px; margin: 20px 0 8px; }
      .btn {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 9px 18px; border-radius: 8px; border: 1px solid var(--border);
        font-size: 0.9rem; font-weight: 600;
      }
      .btn:hover { text-decoration: none; }
      .btn-primary { background: var(--accent); color: #fff; border-color: var(--accent); }
      .btn-primary:hover { background: var(--accent-hover); }
      .btn-secondary { background: var(--bg); color: var(--text); }
      .btn-secondary:hover { background: var(--bg-soft); }

      .screenshot { border: 1px solid var(--border); border-radius: var(--radius); margin: 20px 0; }

      .prose { margin-top: 24px; }
      .prose h2 {
        font-size: 1.25rem; margin-top: 32px; border-left: 4px solid var(--accent);
        padding-left: 10px; line-height: 1.3;
      }
      .prose h3 { font-size: 1.1rem; margin-top: 24px; }
      .prose pre { background: #0f172a; color: #e2e8f0; padding: 16px; border-radius: 8px; overflow-x: auto; }
      .prose code { font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; font-size: 0.9em; }
      .prose :not(pre) > code { background: var(--bg-soft); padding: 2px 6px; border-radius: 4px; }
      .prose img { border-radius: 8px; margin: 12px 0; }

      @media (max-width: 600px) {
        .profile h1 { font-size: 1.6rem; }
        main.container { padding-block: 28px 48px; }
        section { margin-top: 40px; }
      }

      @media (prefers-reduced-motion: reduce) {
        html { scroll-behavior: auto; }
        * { transition: none !important; }
      }
    </style>
  </body>
</html>
